# Copy to .env.local and fill in real values. Never commit .env or .env.local.

# --- OpenAI (required for /tutor) ---
OPENAI_API_KEY=sk-...

# --- Experimental prompt-controlled audio generation (optional) ---
# scripts/generate-openai-audio.js is useful for comparison only. It is not the
# recommended production source for Nahuatl pronunciation because general TTS can
# fall back to Spanish/English phonology. The script requires CONFIRM_TTS_SPEND=YES
# before it calls the paid TTS API.
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=marin
# OPENAI_TTS_FORMAT=wav
# OPENAI_TTS_SPEED=0.86
# NAHUATL_TTS_INPUT_MODE=orthography
# AUDIO_OUT_DIR=public/audio

# --- Experimental Google Cloud TTS pronunciation-rule audio (optional) ---
# Uses SSML phoneme tags with a Spanish voice. Store service-account JSON in
# secrets/ or set GOOGLE_APPLICATION_CREDENTIALS to its absolute path.
# GOOGLE_APPLICATION_CREDENTIALS=C:\absolute\path\to\service-account.json
# GOOGLE_TTS_LANGUAGE_CODE=es-US
# GOOGLE_TTS_VOICE_NAME=es-US-Standard-A
# GOOGLE_TTS_AUDIO_ENCODING=LINEAR16
# GOOGLE_TTS_FORMAT=wav
# GOOGLE_TTS_SPEAKING_RATE=0.82
# GOOGLE_TTS_PITCH=0
# NAHUATL_GOOGLE_INPUT_MODE=phoneme

# --- Audio hosting override (optional) ---
# Default is the S3 audio prefix in src/lib/audio.ts. For a local demo after
# generating into public/audio, use:
# NEXT_PUBLIC_AUDIO_BASE_URL=/audio

# --- Clerk (required — app auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- Neon Postgres (required for cloud progress sync + chat audit log) ---
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- Optional SQLite override ---
# DATABASE_PATH=/absolute/path/to/fcn_master_lexicon_phase8_6_primer.sqlite

# --- Guardrail tuning (all optional) ---

# Replaces the canned refusal string returned when a message is blocked.
# Keep this out of source so attackers can't grep the public repo for a
# sentinel that confirms a bypass succeeded.
# GUARDRAIL_REFUSAL_TEXT="<your private refusal wording here>"

# Additional hard-block regex patterns merged into the public HARD_PATTERNS
# list at startup. JSON array of {name, re} objects. Patterns are compiled
# with the `i` flag. Invalid entries are skipped with a warning.
#   Example (single line — your deploy platform may need escaped quotes):
#   GUARDRAIL_EXTRA_PATTERNS=[{"name":"rule_a","re":"secret phrase \\\\d+"},{"name":"rule_b","re":"another attack"}]
# GUARDRAIL_EXTRA_PATTERNS=
