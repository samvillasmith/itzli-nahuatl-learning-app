# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local cloud credentials
/secrets/
/secret/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite databases (exceed GitHub's 100MB limit — fetched from S3 at build time)
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite.bak
*.db
*.bak

# Audio files (served from S3 — see scripts/fetch-db.js and src/lib/audio.ts)
/public/audio/
/public/audio-google/
image-gallery.html

# Python build artifacts (ml/* has its own .gitignore too)
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Generated morphology cache — regenerate via: python -m ehn_morph build-cache --out data/morphology_cache.json
/data/
